{
  "name": "basic-backend-api",
  "version": "1.1.0",
  "description": "Node + Express backend API",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "dev:test": "dotenv -e .env.test -- nodemon server.js",
    "start": "node server.js",
    "db:push": "prisma db push",
    "db:push:test": "dotenv -e .env.test -- prisma db push",
    "studio": "prisma studio",
    "studio:test": "dotenv -e .env.test -- prisma studio",
    "test": "jest --testPathPatterns test/ --verbose"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.0",
    "helmet": "^7.1.0",
    "mongoose": "^8.4.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.5",
    "prisma": "^6.19.3"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "jest": "^30.4.2",
    "nodemon": "^3.0.3"
  },
  "allowScripts": {
    "@prisma/engines@6.19.3": true,
    "prisma@6.19.3": true,
    "@prisma/client@6.19.3": true
  }
}
