generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  email          String   @unique @db.VarChar(255)
  userName       String   @map("user_name") @db.VarChar(30)
  hashedPassword String   @map("hashed_password") @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  patterns Pattern[]

  @@map("users")
}

model Pattern {
  id             Int      @id @default(autoincrement())
  patternName    String   @map("pattern_name") @db.VarChar(30)
  originalImgUrl String   @map("original_img_url")
  patternImgUrl  String   @map("pattern_img_url")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(6)
  userId         Int      @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("patterns")
}
